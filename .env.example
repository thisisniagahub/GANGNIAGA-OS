# ─── Database (Local Development) ────────────────────────────────────────────
DATABASE_URL="file:./db/custom.db"

# ─── Supabase (Production Database — Required for Vercel) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ─── AI Provider (At least one required for AI features) ─────────────────────
# Option 1: Z AI SDK (auto-detected in sandbox environment)
# ZAI_BASE_URL=http://172.25.136.193:8080/v1
# ZAI_API_KEY=Z.ai

# Option 2: OpenAI (for production/Vercel)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_TTS_MODEL=tts-1
# OPENAI_ASR_MODEL=whisper-1

# Option 3: OpenRouter (for production/Vercel — supports multiple models)
# OPENROUTER_API_KEY_1=sk-or-...
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_APP_NAME=GangNiaga AI OS
# OPENROUTER_APP_URL=https://gangniaga.ai

# ─── Authentication (NextAuth.js) ────────────────────────────────────────────
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── App Settings ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GangNiaga AI OS
