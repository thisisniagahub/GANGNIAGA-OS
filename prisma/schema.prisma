generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"  // Change to "postgresql" for Vercel/production deployment
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  avatar       String?
  role         String        @default("owner")
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Organization {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  industry    String?
  size        String?
  country     String?
  users       User[]
  plans       BusinessPlan[]
  forecasts   Forecast[]
  agents      AgentSession[]
  workflows   WorkflowRun[]
  reports     Report[]
  kpis        KPIData[]
  memories    AgentMemory[]
  ideaCanvases IdeaCanvas[]
  planReviews PlanReview[]
  planActuals PlanActual[]
  pitchDecks  PitchDeck[]
  citations   Citation[]
  integrations Integration[]
  openclawChannels OpenClawChannel[]
  openclawGateways OpenClawGateway[]
  openclawPlugins OpenClawPlugin[]
  openclawDelegates OpenClawDelegate[]
  openclawWebhooks OpenClawWebhook[]
  openclawScheduledTasks OpenClawScheduledTask[]
  openclawSoulConfigs OpenClawSoulConfig[]
  gatewayConversations GatewayConversation[]
  skills        Skill[]
  memoriesV2    AgentMemoryV2[]
  chatSessions  ChatSession[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model BusinessPlan {
  id             String       @id @default(cuid())
  title          String
  status         String       @default("draft")
  executiveSummary String?
  marketAnalysis String?
  swotAnalysis   String?
  competitorAnalysis String?
  financialPlan  String?
  riskAnalysis   String?
  recommendations String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Forecast {
  id             String       @id @default(cuid())
  name           String
  type           String       @default("revenue")
  period         String
  data           String       // JSON string
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model AgentSession {
  id             String       @id @default(cuid())
  name           String
  type           String       @default("general")
  status         String       @default("idle")
  tasksCompleted Int          @default(0)
  lastActivity   DateTime?
  config         String?      // JSON string
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  tasks          AgentTask[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model AgentTask {
  id          String      @id @default(cuid())
  sessionId   String
  session     AgentSession @relation(fields: [sessionId], references: [id])
  type        String
  status      String      @default("pending")
  input       String?
  output      String?
  duration    Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model AgentMemory {
  id             String       @id @default(cuid())
  type           String       @default("workspace")
  category       String?
  content        String
  embedding      String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

model WorkflowRun {
  id             String       @id @default(cuid())
  name           String
  type           String       @default("scheduled")
  status         String       @default("pending")
  triggerType    String       @default("manual")
  steps          String?      // JSON string
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model KPIData {
  id             String       @id @default(cuid())
  metric         String
  value          Float
  previousValue  Float?
  target         Float?
  unit           String       @default("currency")
  period         String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Report {
  id             String       @id @default(cuid())
  title          String
  type           String       @default("investor")
  status         String       @default("generated")
  content        String?      // JSON string
  format         String       @default("pdf")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ── NEW: Idea Canvas & Validation Engine ──

model IdeaCanvas {
  id             String       @id @default(cuid())
  title          String
  status         String       @default("draft") // draft, validating, validated, needs_rework
  problem        String?
  solution       String?
  targetMarket   String?
  revenueModel   String?
  competitiveEdge String?
  risks          String?      // JSON array
  validationScore Float?      @default(0) // 0-100
  validationReport String?    // JSON
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ── NEW: Plan Review Agent Results ──

model PlanReview {
  id             String       @id @default(cuid())
  planId         String
  status         String       @default("pending") // pending, running, completed
  lenderPersona  String       @default("bank") // bank, investor, grant_officer
  narrativeScore Float?       @default(0) // 0-100
  financialScore Float?       @default(0) // 0-100
  consistencyScore Float?     @default(0) // 0-100
  overallScore   Float?       @default(0) // 0-100
  discrepancies  String?     // JSON array of flagged issues
  recommendations String?    // JSON array
  fullReport     String?     // JSON
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ── NEW: Plan vs Actuals Tracking ──

model PlanActual {
  id             String       @id @default(cuid())
  category       String       // revenue, expense, cashflow, profit
  period         String       // 2025-01, 2025-02, etc.
  plannedAmount  Float        @default(0)
  actualAmount   Float?       @default(0)
  variance       Float?       @default(0)
  variancePercent Float?      @default(0)
  source         String       @default("manual") // manual, quickbooks, xero
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ── NEW: Pitch Deck ──

model PitchDeck {
  id             String       @id @default(cuid())
  title          String
  status         String       @default("draft") // draft, generating, completed
  planId         String?      // linked business plan
  templateType   String       @default("investor") // investor, bank, grant
  slides         String?      // JSON array of slide data
  slideCount     Int          @default(0)
  anticipatedQuestions String? // JSON array
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ── NEW: Citations (Bank-Grade Research) ──

model Citation {
  id             String       @id @default(cuid())
  source         String       // name of source
  url            String?
  type           String       @default("market_data") // market_data, industry_report, benchmark, government, financial
  geography      String?      // MY, SEA, Global
  datePublished  String?
  dataPoint      String?      // what data was extracted
  verified       Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

// ── NEW: Integrations (QuickBooks/Xero) ──

model Integration {
  id             String       @id @default(cuid())
  type           String       // quickbooks, xero, manual
  status         String       @default("disconnected") // connected, disconnected, error
  lastSync       DateTime?
  syncFrequency  String       @default("monthly") // daily, weekly, monthly
  config         String?      // JSON
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ── OpenClaw Integration ──

model OpenClawChannel {
  id             String   @id @default(cuid())
  type           String   // whatsapp, telegram, discord, slack, etc.
  name           String
  status         String   @default("disconnected") // connected, disconnected, connecting, error, pending_approval
  lastMessage    String?
  lastMessageAt  DateTime?
  messageCount   Int      @default(0)
  config         String?  // JSON object
  pairedAt       DateTime?
  avatarUrl      String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model OpenClawGateway {
  id               String   @id @default(cuid())
  status           String   @default("unconfigured") // running, stopped, starting, error, unconfigured
  bindHost         String   @default("127.0.0.1")
  bindPort         Int      @default(18789)
  uptime           Int      @default(0) // seconds
  connectedClients Int      @default(0)
  activeChannels   Int      @default(0)
  totalMessages    Int      @default(0)
  lastHealthCheck  DateTime?
  version          String?
  config           String?  // JSON object with authMode, logLevel, etc.
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model OpenClawPlugin {
  id             String   @id @default(cuid())
  name           String
  version        String   @default("1.0.0")
  description    String?
  author         String?
  capabilities   String?  // JSON array
  status         String   @default("available") // installed, enabled, disabled, error, available
  source         String   @default("clawhub") // bundled, clawhub, local
  installedAt    DateTime?
  lastUpdated    DateTime?
  config         String?  // JSON object
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model OpenClawDelegate {
  id             String   @id @default(cuid())
  name           String
  email          String
  displayName    String
  tier           String   @default("tier1_readonly") // tier1_readonly, tier2_send_behalf, tier3_proactive
  status         String   @default("setup") // active, inactive, suspended, setup
  channels       String?  // JSON array of channel types
  principalName  String?
  principalEmail String?
  standingOrders String?  // JSON array
  tasksCompleted Int      @default(0)
  lastActivity   DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model OpenClawWebhook {
  id             String   @id @default(cuid())
  name           String
  url            String
  method         String   @default("POST")
  events         String?  // JSON array
  status         String   @default("active")
  lastTriggered  DateTime?
  triggerCount   Int      @default(0)
  secret         String?
  headers        String?  // JSON object
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model OpenClawScheduledTask {
  id             String   @id @default(cuid())
  name           String
  cronExpression String
  status         String   @default("active") // active, paused, error, completed
  agentId        String?
  prompt         String?
  channel        String?
  lastRun        DateTime?
  nextRun        DateTime?
  runCount       Int      @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model OpenClawSoulConfig {
  id             String   @id @default(cuid())
  personality    String   @default("Professional, knowledgeable, and supportive ASEAN SME business assistant")
  tone           String   @default("Professional yet approachable; uses Malaysian business English")
  language       String   @default("English (with Bahasa Melayu and Mandarin loan words where appropriate)")
  specialty      String   @default("ASEAN SME business planning, financial modeling, and market analysis")
  greeting       String   @default("Hello! I'm your AI business assistant for GangNiaga. How can I help you grow your business today?")
  rules          String   @default("[]") // JSON array of strings
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ── Gateway Messaging Conversations ──

model GatewayConversation {
  id             String   @id @default(cuid())
  platform       String   // telegram, whatsapp, discord, etc.
  platformUserId String   // Unique user ID on the platform (e.g., Telegram chat ID, WhatsApp phone number)
  userName       String?  // Display name from the platform
  direction      String   // inbound, outbound
  messageType    String   @default("text") // text, voice, image, system
  content        String   // Message content
  metadata       String?  // JSON: additional platform-specific data (message_id, raw payload, etc.)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
}

// ── Hermes-Inspired: Skills System ──

model Skill {
  id             String   @id @default(cuid())
  name           String   @unique
  slug           String   @unique
  description    String
  version        String   @default("1.0.0")
  category       String   @default("general") // general, business, financial, marketing, research, automation
  content        String   // The skill instructions/knowledge (markdown)
  triggerPhrase  String?  // Slash command trigger e.g. "/market-analysis"
  tags           String?  // JSON array of tags
  usageCount     Int      @default(0)
  lastUsedAt     DateTime?
  source         String   @default("user_created") // user_created, ai_generated, bundled, hub
  status         String   @default("active") // active, deprecated, draft
  autoLearn      Boolean  @default(false) // Can this skill auto-improve from conversations?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ── Hermes-Inspired: Persistent Memory ──

model AgentMemoryV2 {
  id             String   @id @default(cuid())
  type           String   @default("memory") // memory, user_profile
  key            String   // Short label for this memory entry
  content        String   // The actual memory content
  importance     Int      @default(5) // 1-10 importance score
  charLimit      Int      @default(500) // Max chars for this entry
  sessionId      String?  // Which session created this memory
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ── Hermes-Inspired: Chat Sessions ──

model ChatSession {
  id             String   @id @default(cuid())
  title          String?
  platform       String   @default("web") // web, telegram, whatsapp, discord, slack
  platformSessionId String? // External platform session ID
  messages       String   @default("[]") // JSON array of messages
  memorySnapshot String?  // Frozen memory at session start
  soulSnapshot   String?  // Frozen SOUL.md at session start
  skillsUsed     String?  // JSON array of skill IDs used
  status         String   @default("active") // active, ended, archived
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
