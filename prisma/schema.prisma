generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  avatar       String?
  role         String        @default("owner")
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Organization {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  industry    String?
  size        String?
  country     String?
  users       User[]
  plans       BusinessPlan[]
  forecasts   Forecast[]
  agents      AgentSession[]
  workflows   WorkflowRun[]
  reports     Report[]
  kpis        KPIData[]
  memories    AgentMemory[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model BusinessPlan {
  id             String       @id @default(cuid())
  title          String
  status         String       @default("draft")
  executiveSummary String?
  marketAnalysis String?
  swotAnalysis   String?
  competitorAnalysis String?
  financialPlan  String?
  riskAnalysis   String?
  recommendations String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Forecast {
  id             String       @id @default(cuid())
  name           String
  type           String       @default("revenue")
  period         String
  data           String       // JSON string
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model AgentSession {
  id             String       @id @default(cuid())
  name           String
  type           String       @default("general")
  status         String       @default("idle")
  tasksCompleted Int          @default(0)
  lastActivity   DateTime?
  config         String?      // JSON string
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  tasks          AgentTask[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model AgentTask {
  id          String      @id @default(cuid())
  sessionId   String
  session     AgentSession @relation(fields: [sessionId], references: [id])
  type        String
  status      String      @default("pending")
  input       String?
  output      String?
  duration    Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model AgentMemory {
  id             String       @id @default(cuid())
  type           String       @default("workspace")
  category       String?
  content        String
  embedding      String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

model WorkflowRun {
  id             String       @id @default(cuid())
  name           String
  type           String       @default("scheduled")
  status         String       @default("pending")
  triggerType    String       @default("manual")
  steps          String?      // JSON string
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model KPIData {
  id             String       @id @default(cuid())
  metric         String
  value          Float
  previousValue  Float?
  target         Float?
  unit           String       @default("currency")
  period         String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Report {
  id             String       @id @default(cuid())
  title          String
  type           String       @default("investor")
  status         String       @default("generated")
  content        String?      // JSON string
  format         String       @default("pdf")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
