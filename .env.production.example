# ─── Vercel Production Environment Variables ───────────────────
# Copy this file to .env.production and fill in your actual values.
# These variables are required for deploying GangNiaga AI OS to Vercel.
#
# Setup:
#   1. Create a PostgreSQL database (Vercel Postgres, Neon, or Supabase)
#   2. Copy this file: cp .env.production.example .env.production
#   3. Fill in all values below
#   4. Update Prisma schema provider to "postgresql" before deploying
#   5. Run: bash scripts/setup-vercel.sh
# ──────────────────────────────────────────────────────────────

# ─── Database (PostgreSQL required for Vercel) ────────────────
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# ─── AI SDK ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ─── Authentication (NextAuth.js) ─────────────────────────────
NEXTAUTH_SECRET=your-random-secret
NEXTAUTH_URL=https://your-app.vercel.app

# ─── App Settings ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_NAME=GangNiaga AI OS
